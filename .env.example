# Base44 SDK (required for frontend)
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=

# Gemini API key for online image analysis (vision only, NOT for TTS)
GEMINI_API_KEY=
# Optional: override vision model (default: gemini-2.5-flash)
# VISION_MODEL=gemini-2.5-flash

# Server port (Render sets PORT automatically)
# PORT=3001
